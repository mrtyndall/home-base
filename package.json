{
  "name": "home-base",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "test": "tsx --test scripts/*.test.ts",
    "test:read-later-postgres": "tsx scripts/read-later-postgres.integration.ts",
    "test:hierarchy-postgres": "tsx scripts/hierarchy-postgres.integration.ts",
    "build": "prisma generate && next build && npm run build:standalone-assets",
    "build:standalone-assets": "rm -rf .next/standalone/.next/static .next/standalone/public && mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public",
    "start": "prisma migrate deploy && DOTENV_CONFIG_PATH=.env.local HOSTNAME=0.0.0.0 PORT=${PORT:-3002} node -r dotenv/config .next/standalone/server.js",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "verify:area-migration": "tsx scripts/verify-area-first-migration.ts",
    "verify:area-release": "tsx scripts/verify-area-first-release.ts",
    "verify:hierarchy-release": "tsx scripts/verify-hierarchy-release.ts",
    "verify:agent-integration": "tsx scripts/verify-agent-integration.ts",
    "backup:db": "tsx scripts/backup-database.ts",
    "references:artwork": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/enrich-reference-artwork.ts",
    "import:reminders": "tsx scripts/import-apple-reminders.ts",
    "calendar:sync": "tsx scripts/sync-google-calendar.ts",
    "reminders:send": "tsx scripts/send-reminders.ts",
    "api:key:register": "tsx scripts/register-api-key.ts",
    "mcp:http": "tsx mcp/http-server.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "csv-parse": "^7.0.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rrule": "^2.8.1",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
