DATABASE_URL="postgresql://user:password@host:5432/home_base?sslmode=require"
ANTHROPIC_API_KEY="your-api-key-here"
ANTHROPIC_PARSE_MODEL="claude-sonnet-4-5"
DB_POOL_MAX="10"
DB_POOL_CONNECTION_TIMEOUT_MS="5000"

# S3-compatible database backups, such as Cloudflare R2.
S3_BACKUP_BUCKET=""
S3_BACKUP_ENDPOINT=""
S3_BACKUP_REGION="auto"
S3_BACKUP_ACCESS_KEY_ID=""
S3_BACKUP_SECRET_ACCESS_KEY=""
BACKUP_DIR=""

# Future integrations.
PUSHOVER_USER_KEY=""
PUSHOVER_APP_TOKEN=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://your-railway-domain.up.railway.app/api/google/oauth/callback"
GOOGLE_CALENDAR_ID="primary"
GOOGLE_TOKEN_ENCRYPTION_KEY=""
GOOGLE_OAUTH_STATE_SECRET=""
MCP_PORT="8081"
