generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CaptureSource {
  in_app_text
  in_app_voice
  ios_shortcut
  android_shortcut
  api
}

enum CaptureParseStatus {
  parsed
  ambiguous
  failed
}

enum ProjectStatus {
  someday
  active
  parked
  completed
  killed
}

enum TaskStatus {
  open
  completed
  killed
}

enum IdeaStatus {
  seed
  developing
  converted
  killed
}

enum ConvertedToType {
  task
  project
}

enum CalendarEventSource {
  google
  capture
  manual
  api
}

enum NudgeTrigger {
  clustering
  time_sensitive
}

enum ReminderChannel {
  pushover
  in_app
}

enum ReminderDeliveryStatus {
  sent
  failed
}

enum CalendarSyncStatus {
  ok
  stale
  failed
  not_configured
}

enum AreaStatus {
  active
  parked
  retired
}

enum EntityParentType {
  area
  project
}

enum EntityDocStatus {
  active
  archived
}

enum MilestoneStatus {
  open
  completed
}

model Capture {
  id            String              @id @default(uuid())
  rawText       String              @map("raw_text")
  source        CaptureSource
  deviceContext Json?               @map("device_context")
  parseStatus   CaptureParseStatus? @map("parse_status")
  parsedActions Json?               @map("parsed_actions")
  createdItems  Json?               @map("created_items")
  createdAt     DateTime            @default(now()) @map("created_at")

  calendarEvents  CalendarEvent[]
  entityDocs      EntityDoc[]
  entityNotes     EntityNote[]
  ideaNotes       IdeaNote[]
  ideas           Idea[]
  projectActivity ProjectActivity[]
  references      Reference[]
  tasks           Task[]

  @@index([createdAt])
  @@index([parseStatus])
  @@map("captures")
}

model Domain {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  sortOrder   Int     @default(0) @map("sort_order")
  isSystem    Boolean @default(false) @map("is_system")
  active      Boolean @default(true)

  areas Area[]

  @@index([active, sortOrder])
  @@map("domains")
}

model Area {
  id             String     @id @default(uuid())
  name           String
  domainId       String     @map("domain_id")
  status         AreaStatus @default(active)
  currentState   String?    @map("current_state")
  nextStep       String?    @map("next_step")
  tendingCadence String?    @map("tending_cadence")
  sortOrder      Int        @default(0) @map("sort_order")
  isSystem       Boolean    @default(false) @map("is_system")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  domain     Domain      @relation(fields: [domainId], references: [id])
  ideas      Idea[]
  projects   Project[]
  references Reference[]
  tasks      Task[]

  @@index([domainId, status, sortOrder])
  @@index([status, sortOrder])
  @@map("areas")
}

model Project {
  id                String        @id @default(uuid())
  name              String
  areaId            String        @map("area_id")
  status            ProjectStatus @default(active)
  currentState      String?       @map("current_state")
  nextStep          String?       @map("next_step")
  targetDate        DateTime?     @map("target_date") @db.Date
  slipThresholdDays Int           @default(14) @map("slip_threshold_days")
  parkedAt          DateTime?     @map("parked_at")
  completedAt       DateTime?     @map("completed_at")
  killedAt          DateTime?     @map("killed_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  area       Area              @relation(fields: [areaId], references: [id])
  activity   ProjectActivity[]
  ideas      Idea[]
  references Reference[]
  milestones Milestone[]
  tasks      Task[]

  @@index([areaId, status])
  @@index([targetDate])
  @@map("projects")
}

model ProjectActivity {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  entry         String
  stateSnapshot Json?    @map("state_snapshot")
  source        String
  captureId     String?  @map("capture_id")
  createdAt     DateTime @default(now()) @map("created_at")

  capture Capture? @relation(fields: [captureId], references: [id])
  project Project  @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([captureId])
  @@map("project_activity")
}

model Task {
  id              String     @id @default(uuid())
  title           String
  notes           String?
  status          TaskStatus @default(open)
  dueDate         DateTime?  @map("due_date") @db.Date
  dueTime         String?    @map("due_time")
  priority        String?
  areaId          String     @default("area_inbox") @map("area_id")
  projectId       String?    @map("project_id")
  parentTaskId    String?    @map("parent_task_id")
  someday         Boolean    @default(false)
  starred         Boolean    @default(false)
  recurrenceRule  String?    @map("recurrence_rule")
  reminderOffsets Json?      @map("reminder_offsets")
  source          String?
  captureId       String?    @map("capture_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  completedAt     DateTime?  @map("completed_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  capture            Capture?           @relation(fields: [captureId], references: [id])
  area               Area               @relation(fields: [areaId], references: [id])
  parent             Task?              @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  project            Project?           @relation(fields: [projectId], references: [id])
  reminderDeliveries ReminderDelivery[]
  subtasks           Task[]             @relation("TaskSubtasks")

  @@index([areaId, status])
  @@index([someday, status])
  @@index([starred, status])
  @@index([dueDate, dueTime])
  @@index([projectId])
  @@index([captureId])
  @@map("tasks")
}

model Idea {
  id              String           @id @default(uuid())
  title           String
  body            String?
  areaId          String?          @map("area_id")
  projectId       String?          @map("project_id")
  tags            String[]         @default([])
  status          IdeaStatus       @default(seed)
  convertedToType ConvertedToType? @map("converted_to_type")
  convertedToId   String?          @map("converted_to_id")
  source          String?
  captureId       String?          @map("capture_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  capture Capture?   @relation(fields: [captureId], references: [id])
  area    Area?      @relation(fields: [areaId], references: [id])
  project Project?   @relation(fields: [projectId], references: [id])
  notes   IdeaNote[]

  @@index([areaId, status])
  @@index([projectId, status])
  @@index([captureId])
  @@map("ideas")
}

model IdeaNote {
  id        String   @id @default(uuid())
  ideaId    String   @map("idea_id")
  body      String
  source    String?
  captureId String?  @map("capture_id")
  createdAt DateTime @default(now()) @map("created_at")

  capture Capture? @relation(fields: [captureId], references: [id])
  idea    Idea     @relation(fields: [ideaId], references: [id])

  @@index([ideaId, createdAt])
  @@index([captureId])
  @@map("idea_notes")
}

model Reference {
  id          String   @id @default(uuid())
  body        String
  url         String?
  tags        String[] @default([])
  areaId      String?  @map("area_id")
  projectId   String?  @map("project_id")
  relatedType String?  @map("related_type")
  relatedId   String?  @map("related_id")
  source      String?
  captureId   String?  @map("capture_id")
  createdAt   DateTime @default(now()) @map("created_at")

  capture Capture? @relation(fields: [captureId], references: [id])
  area    Area?    @relation(fields: [areaId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([areaId])
  @@index([projectId])
  @@index([captureId])
  @@map("references")
}

model EntityNote {
  id         String           @id @default(uuid())
  parentType EntityParentType @map("parent_type")
  parentId   String           @map("parent_id")
  bodyMd     String           @map("body_md")
  source     String?
  captureId  String?          @map("capture_id")
  createdAt  DateTime         @default(now()) @map("created_at")

  capture Capture? @relation(fields: [captureId], references: [id])

  @@index([parentType, parentId, createdAt])
  @@index([captureId])
  @@map("entity_notes")
}

model EntityDoc {
  id         String           @id @default(uuid())
  parentType EntityParentType @map("parent_type")
  parentId   String           @map("parent_id")
  title      String
  bodyMd     String           @map("body_md")
  status     EntityDocStatus  @default(active)
  source     String?
  captureId  String?          @map("capture_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  capture Capture? @relation(fields: [captureId], references: [id])

  @@index([parentType, parentId, status])
  @@index([captureId])
  @@map("entity_docs")
}

model Document {
  id         String           @id @default(uuid())
  parentType EntityParentType @map("parent_type")
  parentId   String           @map("parent_id")
  filename   String
  r2Key      String           @map("r2_key")
  mime       String
  size       Int
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([parentType, parentId])
  @@map("documents")
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  title       String
  status      MilestoneStatus @default(open)
  sortOrder   Int             @default(0) @map("sort_order")
  completedAt DateTime?       @map("completed_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, status, sortOrder])
  @@map("milestones")
}

model CalendarEvent {
  id               String              @id @default(uuid())
  googleEventId    String?             @unique @map("google_event_id")
  googleCalendarId String?             @map("google_calendar_id")
  googleEtag       String?             @map("google_etag")
  googleUpdatedAt  DateTime?           @map("google_updated_at")
  title            String
  start            DateTime
  end              DateTime
  location         String?
  status           String              @default("confirmed")
  syncedAt         DateTime?           @map("synced_at")
  lastPushedAt     DateTime?           @map("last_pushed_at")
  lastPulledAt     DateTime?           @map("last_pulled_at")
  source           CalendarEventSource @default(manual)
  captureId        String?             @map("capture_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  capture Capture? @relation(fields: [captureId], references: [id])

  @@index([start, end])
  @@index([captureId])
  @@index([googleCalendarId, syncedAt])
  @@map("calendar_events")
}

model Notification {
  id          String   @id @default(uuid())
  type        String
  title       String
  body        String?
  sourceRef   Json?    @map("source_ref")
  status      String   @default("unread")
  undoPayload Json?    @map("undo_payload")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("notifications")
}

model Nudge {
  id             String       @id @default(uuid())
  trigger        NudgeTrigger
  title          String
  body           String
  supportingData Json?        @map("supporting_data")
  sentAt         DateTime?    @map("sent_at")
  actedOn        Boolean?     @map("acted_on")

  @@index([trigger, sentAt])
  @@map("nudges")
}

model CaptureToken {
  id               String    @id @default(uuid())
  tokenHash        String    @unique @map("token_hash")
  label            String
  deviceName       String    @map("device_name")
  rateLimitPerHour Int       @default(60) @map("rate_limit_per_hour")
  lastUsedAt       DateTime? @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")

  @@index([revokedAt])
  @@map("capture_tokens")
}

model ReminderDelivery {
  id             String                 @id @default(uuid())
  taskId         String                 @map("task_id")
  offsetMinutes  Int                    @map("offset_minutes")
  channel        ReminderChannel
  sentAt         DateTime               @default(now()) @map("sent_at")
  deliveryStatus ReminderDeliveryStatus @map("delivery_status")
  error          String?

  task Task @relation(fields: [taskId], references: [id])

  @@unique([taskId, offsetMinutes, channel])
  @@index([sentAt])
  @@map("reminder_deliveries")
}

model ApiKey {
  id         String    @id @default(uuid())
  tokenHash  String    @unique @map("token_hash")
  label      String
  scopes     Json
  rateLimit  Int       @default(60) @map("rate_limit")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([revokedAt])
  @@map("api_keys")
}

model CalendarSyncState {
  id                   String             @id @default("google-primary")
  provider             String             @default("google")
  calendarId           String?            @map("calendar_id")
  syncToken            String?            @map("sync_token")
  lastSyncedAt         DateTime?          @map("last_synced_at")
  lastSuccessfulSyncAt DateTime?          @map("last_successful_sync_at")
  status               CalendarSyncStatus @default(not_configured)
  error                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("calendar_sync_states")
}

model CalendarOAuthToken {
  id                     String    @id @default("google-primary")
  provider               String    @default("google")
  calendarId             String    @default("primary") @map("calendar_id")
  refreshTokenCiphertext String    @map("refresh_token_ciphertext")
  refreshTokenIv         String    @map("refresh_token_iv")
  refreshTokenTag        String    @map("refresh_token_tag")
  scope                  String?
  tokenType              String?   @map("token_type")
  expiryDate             DateTime? @map("expiry_date")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@map("calendar_oauth_tokens")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
