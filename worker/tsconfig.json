{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "outDir": "dist",
    "noEmitOnError": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../src/lib/agent/schemas.ts"]
}
